# ── Server ───────────────────────────────────────────────────────
PORT = 8000
# MONGODB_URL = 'mongodb://127.0.0.1:27017/dating-application'
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=""
DB_NAME=fitness_application
DB_PORT=3306

# ── Frontend user JWT ─────────────────────────────────────────────
SESSION_SECRET =your-session-key
ACCESS_TOKEN_SECRET = mysecuresecret
ACCESS_TOKEN_EXPIRY = 1d
REFRESH_TOKEN_SECRET = mysecuresecretrefreshtoken
REFRESH_TOKEN_EXPIRY = 10d

# ── Admin JWT (SEPARATE secrets - critical for security) ──────────
ADMIN_JWT_SECRET=myAdminSecureSecret
ADMIN_JWT_EXPIRES_IN = 8h
ADMIN_JWT_REFRESH_SECRET=myAdminsecuresecretrefreshtoken
ADMIN_JWT_REFRESH_EXPIRES_IN= 1d


CORS_ORIGIN=*

# ── CORS Origins ──────────────────────────────────────────────────
# FRONTEND_URL=http://localhost:3000
# ADMIN_URL=http://localhost:3001


